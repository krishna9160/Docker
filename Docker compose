=========================== APPLICATION FILES ==================================

-------------------------------- myapp.js --------------------------------------

const http = require("http");
const mysql = require("mysql");

// create DB connection
const db = mysql.createConnection({
  host: "db",  // service name
  user: "root",
  password: "root",
  database: "testdb",
});

// retry connection if DB not ready
function connectDB() {
  db.connect((err) => {
    if (err) {
      console.log("DB not ready, retrying...");
      setTimeout(connectDB, 5000);
    } else {
      console.log("Connected to MySQL ✅");
    }
  });
}

connectDB();

const server = http.createServer((req, res) => {
  res.end("App connected to DB 🚀");
});

server.listen(3000, () => {
  console.log("Server running on port 3000");
});

-------------------------------------------------------------------------------

------------------------------- package.json -----------------------------------

{
  "name": "compose-app",
  "version": "1.0.0",
  "main": "myapp.js",
  "dependencies": {
    "mysql": "^2.18.1"
  }
}

-------------------------------------------------------------------------------

-------------------------------- Dockerfile ------------------------------------

FROM node:18-alpine

WORKDIR /app

COPY package.json .
RUN npm install

COPY myapp.js .

EXPOSE 3000

CMD ["node", "myapp.js"]

-------------------------------------------------------------------------------

----------------------------- docker-compose.yml -------------------------------

version: "3"

services:

  app:
    build: .
    container_name: node-app
    ports:
      - "3000:3000"
    depends_on:
      - db
    restart: always

  db:
    image: mysql:5.7
    container_name: mysql-db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: testdb
    ports:
      - "3306:3306"
    volumes:
      - db-data:/var/lib/mysql

volumes:
  db-data:

